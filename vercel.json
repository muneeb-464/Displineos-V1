{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "routes": [
    { "src": "/auth/(.*)",  "dest": "/api/index.js" },
    { "src": "/api/(.*)",   "dest": "/api/index.js" },
    { "src": "/health",     "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
